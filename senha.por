programa
{
    funcao inicio()
    {
        cadeia senha
 
        faca
        {
            escreva("Digite a senha: ")
            leia(senha)
 
            se (senha != "senhakg")
            {
                escreva("Senha incorreta, tente novamente\n")
            }
 
        } enquanto (senha != "senhakg")
 
        escreva("Acesso liberado! Bem-vindo!")
    }
}